{
  "name": "@_linked/ui",
  "description": "",
  "author": {
    "name": "",
    "email": "",
    "url": ""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "version": "1.0.1",
  "linkedPackage": true,
  "main": "lib/index.js",
  "types": "dist/lincd-ui.d.ts",
  "license": "ISC",
  "scripts": {
    "start": "npm exec linked dev",
    "build": "yarn linked build",
    "prepublishOnly": "yarn linked build production",
    "postpublish": "npm exec linked register"
  },
  "keywords": [
    "lincd",
    "linked data",
    "interoperable",
    "semantic web",
    "web3"
  ],
  "dependencies": {
    "@_linked/core": "^2.0.1",
    "@_linked/primitives": "~1.0",
    "@_linked/schema": "~1.0",
    "@_linked/server": "~1.0",
    "lincd-mui-base": "~1.0",
    "@_linked/react": "^1.2"
  },
  "devDependencies": {
    "@_linked/cli": "^1.2",
    "@capacitor/core": "^5.3.0",
    "@types/node": "^20.14.9",
    "tsconfig-to-dual-package": "^1.2.0",
    "typescript": "^5.7.3",
    "typescript-plugin-css-modules": "^5.1.0"
  },
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./*.js": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "lib/esm/*"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
