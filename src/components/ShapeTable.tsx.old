import React from 'react';
import style from './ShapeTable.module.css';
import {Dialog as RadixDialog} from 'lincd-primitives/components/Dialog';
import {Button} from 'lincd-primitives/components/Button';
import {Select} from 'lincd-primitives/components/Select';
import {FormField} from '../components/molecules/FormField.js';
import {asset} from 'lincd/utils/LinkedFileStorage';
import {Badge} from '../atoms/Badge.js';
import {Icons} from '../Icons.js';
import {useNavigate, Routes, useParams, useLocation} from 'react-router-dom';
import {cl} from 'lincd/utils/ClassNames';
import {
  Column,
  ColumnDef,
  PaginationState,
  Table,
  flexRender,
  getCoreRowModel,
  getFilteredRowModel,
  getPaginationRowModel,
  getSortedRowModel,
  useReactTable,
} from '@tanstack/react-table';
import {Link} from 'react-router-dom';
import {getShapeNameFromParams, getShapeParamsFromUri} from '../utils.js';
import {ROUTES} from '../routes.js';
import {ShapeSet} from 'lincd/collections/ShapeSet';
import {Person as SchemaPerson} from 'lincd-schema/shapes/Person';
import {PersonOnly} from './makeData.js';

// type Person = {
//   firstName: string;
//   lastName: string | undefined;
//   age: number;
//   visits: number | undefined;
//   progress: number;
//   status: 'relationship' | 'complicated' | 'single';
//   rank: number;
//   createdAt: Date;
//   subRows?: Person[];
// };

//Rename to ShapeTable
function ShapeTable({
  data,
  columns,
  toggleSelectAll,
  isRowSelected,
  selectedRows,
  toggleRowSelection,
  isDeleteBtnShowing,
  shape,
}: {
  // data: ShapeSet<any>;
  // columns: ColumnDef<Person>[];
  data: PersonOnly[] | ShapeSet<any>;
  columns: ColumnDef<PersonOnly>[];
  toggleSelectAll: () => void;
  isRowSelected: (index: number) => boolean;
  selectedRows: number[];
  toggleRowSelection: (index: number) => void;
  isDeleteBtnShowing: boolean;
  shape?;
}) {
  const [pagination, setPagination] = React.useState<PaginationState>({
    pageIndex: 0,
    pageSize: 10,
  });
  const [filters, setFilters] = React.useState([]);
  const [filterValue, setFilterValue] = React.useState('');
  const navigate = useNavigate();
  const params = useParams();
  let location = useLocation();
  let routePath = location.pathname + '?';
  console.log('routePath', routePath);

  const table = useReactTable({
    columns,
    data: [...data],
    debugTable: true,
    getCoreRowModel: getCoreRowModel(),
    getSortedRowModel: getSortedRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
    getPaginationRowModel: getPaginationRowModel(),
    onPaginationChange: setPagination,
    state: {
      pagination,
    },
    // autoResetPageIndex: false, // turn off page index reset when sorting or filtering
  });

  const handleFilterSubmit = () => {
    setFilters([...filters, filterValue]);
    setFilterValue('');
  };

  const handleChange = (e) => {
    setFilterValue(e.target.value);
  };

  const handleEdit = (row) => {
    let subject = row.original.uri;
    let subjectId = row.id;
    navigate(
      `${ROUTES.data.path}/${getShapeParamsFromUri(
        shape.uri,
      )}/edit?s${subjectId}=${subject}`,
    );
    // go to .../edit/?s=...
    //next, on edit page, use ?s searchParam to find back the instance
    // let subject = (shapeClass as any).getFromURI(s)
  };

  const handleDelete = (index: number) => {
    // Handle delete action here
    alert('Deleting row with index: ' + index);
    console.log('Deleting row with index:', index);
  };

  const handleDeleteCollectively = () => {
    alert('Deleting collectively index: ' + selectedRows);
    console.log('Deleting collectively', selectedRows);
  };

  const getCellStyle = (cell) => {
    const value = cell.getValue();
    // Define your conditional logic here
    if (value === 'Yes') {
      return style.green; // Assuming styles.highValue is defined in your CSS module
    }
    return ''; // Default case (no additional style)
  };

  return (
    <div className={style.tableWrapper}>
      <div className={style.action}>
        <Link
          to={`${ROUTES.data.path}/${getShapeParamsFromUri(shape.uri)}/add`}
        >
          <Button>
            <img src={asset('/images/icons/user-add.svg')} />
            New {shape.label}
          </Button>
        </Link>
        <RadixDialog.Root>
          <RadixDialog.Trigger asChild>
            <Button variant="link" className={style.filterButton}>
              <img src={asset('/images/icons/filter.svg')} />
            </Button>
          </RadixDialog.Trigger>
          <RadixDialog.Content className={style.modalContainer}>
            <RadixDialog.Header>
              <RadixDialog.Title>Filter</RadixDialog.Title>
              <RadixDialog.Description className="AlertDialogDescription">
                2 filter shown
              </RadixDialog.Description>
              <div className={style.modalBody}>
                <img src={asset('/images/icons/filtering-state.svg')} />
                <div className={style.form}>
                  <div className={style.formSection}>
                    <label>Sort by</label>
                    <Select.Root>
                      <Select.Trigger
                        aria-label="SortBy"
                        style={{width: '100%'}}
                        className={style.formFilter}
                      >
                        <Select.Value placeholder="Select Order" />
                      </Select.Trigger>
                      <Select.Content>
                        <Select.Group>
                          <Select.Item value="newest">Newest</Select.Item>
                          <Select.Item value="latest">Latest</Select.Item>
                        </Select.Group>
                      </Select.Content>
                    </Select.Root>
                  </div>
                  <div
                    className={style.formSection}
                    onSubmit={handleFilterSubmit}
                  >
                    <label>Filter</label>
                    <Select.Root>
                      <Select.Trigger
                        aria-label="SortBy"
                        style={{width: '100%'}}
                        className={style.formFilter}
                      >
                        <Select.Value placeholder="Select Column" />
                      </Select.Trigger>
                      <Select.Content>
                        <Select.Group>
                          {columns.map((column) => (
                            <Select.Item key={column.id} value={column.id}>
                              {column.id}
                            </Select.Item>
                          ))}
                        </Select.Group>
                      </Select.Content>
                    </Select.Root>
                    <p>contains</p>
                    <FormField
                      name={'value'}
                      type={'text'}
                      placeholder="Type Value"
                      className={style.formFilter}
                      onChange={handleChange}
                      value={filterValue}
                    />
                  </div>
                </div>
              </div>
            </RadixDialog.Header>
            <RadixDialog.Footer>
              <RadixDialog.Close asChild>
                <Button
                  className={style.buttonFilter}
                  onClick={handleFilterSubmit}
                >
                  Add Filter
                </Button>
              </RadixDialog.Close>
            </RadixDialog.Footer>
          </RadixDialog.Content>
        </RadixDialog.Root>
      </div>
      <div className={style.tableBar}>
        <div className={style.filterBar}>
          <p>Selected filters:</p>
          {filters.map((filter, index) => (
            <Badge key={index} text={filter} />
          ))}
        </div>
        <div>
          {isDeleteBtnShowing && (
            <Button
              size={'small'}
              variant={'outline'}
              className={style.deleteDataButton}
              onClick={handleDeleteCollectively}
            >
              <Icons.RubbishBin />
              Delete Data
            </Button>
          )}
        </div>
      </div>
      <div className={style.tableContainer}>
        <table className={style.table}>
          <thead>
            {table.getHeaderGroups().map((headerGroup) => (
              <tr key={headerGroup.id} className={style.tr}>
                <th className={cl(style.th, style.sticky, style.stickyLeft)}>
                  <input type="checkbox" onChange={toggleSelectAll} />
                </th>
                {headerGroup.headers.map((header, index) => {
                  return (
                    <th
                      key={header.id}
                      colSpan={header.colSpan}
                      className={style.th}
                    >
                      {index === 0 ? (
                        <div>
                          {flexRender(
                            header.column.columnDef.header,
                            header.getContext(),
                          )}
                        </div>
                      ) : (
                        <div
                          {...{
                            className: header.column.getCanSort()
                              ? style.canSort
                              : '',
                            onClick: header.column.getToggleSortingHandler(),
                          }}
                        >
                          {flexRender(
                            header.column.columnDef.header,
                            header.getContext(),
                          )}
                          {{
                            asc: <Icons.UpArrow />,
                            desc: <Icons.DownArrow />,
                          }[header.column.getIsSorted() as string] ?? (
                            <Icons.LeftRightArrow />
                          )}
                        </div>
                      )}
                    </th>
                  );
                })}
                <th className={cl(style.th, style.sticky, style.stickyRight)}>
                  Actions
                </th>
              </tr>
            ))}
          </thead>
          <tbody>
            {table.getRowModel().rows.map((row) => {
              return (
                <tr key={row.id} className={style.tr}>
                  <td className={cl(style.td, style.sticky, style.stickyLeft)}>
                    <input
                      type="checkbox"
                      onChange={() => toggleRowSelection(row.index)}
                      checked={isRowSelected(row.index)}
                    />
                  </td>
                  {row.getVisibleCells().map((cell) => {
                    return (
                      <td
                        key={cell.id}
                        className={cl(style.td, getCellStyle(cell))}
                      >
                        {flexRender(
                          cell.column.columnDef.cell,
                          cell.getContext(),
                        )}
                      </td>
                    );
                  })}
                  <td className={cl(style.td, style.sticky, style.stickyRight)}>
                    <Button
                      variant="link"
                      className={style.actionTableButton}
                      onClick={() => handleEdit(row)}
                    >
                      <Icons.Pencil />
                    </Button>
                    <Button
                      variant="link"
                      className={style.actionTableButton}
                      onClick={() => handleDelete(row.index)}
                    >
                      <Icons.RubbishBin />
                    </Button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <div className={style.pagination}>
        <span className={style.pageInfo}>
          Page{' '}
          <strong>
            {table.getState().pagination.pageIndex + 1} of{' '}
            {table.getPageCount().toLocaleString()}
          </strong>
        </span>
        <span className={style.pageInfo}>
          <FormField
            type="number"
            className={style.goToPageForm}
            value={table.getState().pagination.pageIndex + 1}
            onChange={(e) => {
              const page = e.target.value ? Number(e.target.value) - 1 : 0;
              table.setPageIndex(page);
            }}
          />
        </span>
        <select
          className={style.selectPageRows}
          value={table.getState().pagination.pageSize}
          onChange={(e) => {
            table.setPageSize(Number(e.target.value));
          }}
        >
          {[10, 20, 30, 40, 50].map((pageSize) => (
            <option key={pageSize} value={pageSize}>
              Show {pageSize}
            </option>
          ))}
        </select>
        <Button
          variant="outline"
          className={style.paginationButton}
          onClick={() => table.firstPage()}
          disabled={!table.getCanPreviousPage()}
        >
          <Icons.DoubleLeftArrow />
        </Button>
        <Button
          variant="outline"
          className={style.paginationButton}
          onClick={() => table.previousPage()}
          disabled={!table.getCanPreviousPage()}
        >
          <Icons.SingleLeftArrow />
        </Button>
        <Button
          variant="outline"
          className={style.paginationButton}
          onClick={() => table.nextPage()}
          disabled={!table.getCanNextPage()}
        >
          <Icons.SingleRightArrow />
        </Button>
        <Button
          variant="outline"
          className={style.paginationButton}
          onClick={() => table.lastPage()}
          disabled={!table.getCanNextPage()}
        >
          <Icons.DoubleRightArrow />
        </Button>
      </div>
    </div>
  );
}

export {ShapeTable};
